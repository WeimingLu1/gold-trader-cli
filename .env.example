# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./gold_trader.db

# ─── LLM ─────────────────────────────────────────────────────────────────────
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=your_openai_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# ─── Scheduling ───────────────────────────────────────────────────────────────
SCHEDULE_INTERVAL_HOURS=4
DEFAULT_HORIZON_HOURS=4

# ─── Data Sources ─────────────────────────────────────────────────────────────
# Gold price API (optional — mock used if not set)
GOLD_API_KEY=

# News API (optional)
NEWS_API_KEY=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── Strategy ────────────────────────────────────────────────────────────────
WEIGHTS_FILE=config/weights.yaml
